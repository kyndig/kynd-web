{
  "name": "kynd-web",
  "type": "module",
  "version": "0.0.1",
  "private": true,
  "homepage": "https://kynd.no",
  "author": {
    "name": "Frederik Gørvell de Lichtenberg",
    "email": "frederik@kynd.no",
    "url": "https://github.com/frederikgdl"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/kynd-no/kynd-web"
  },
  "packageManager": "pnpm@10.24.0",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "astro:check": "astro check",
    "typecheck": "tsc",
    "lint": "eslint src --max-warnings 0",
    "prettier:check": "prettier --check . --plugin=prettier-plugin-astro  --experimental-cli",
    "prettier:format": "prettier --write . --plugin=prettier-plugin-astro",
    "check": "pnpm astro:check && pnpm typecheck && pnpm lint && pnpm prettier:check",
    "ci:local": "pnpm install --frozen-lockfile && pnpm check && pnpm build",
    "check:fix": "pnpm lint --fix && pnpm prettier:format",
    "test:e2e:contact-cta": "playwright test tests/e2e/contact-cta-contrast.spec.ts",
    "preinstall": "npx only-allow pnpm",
    "handbook:create": "node scripts/create-handbook.js",
    "test:e2e": "pnpm build && playwright test",
    "test:e2e:ci": "playwright test"
  },
  "dependencies": {
    "@astrojs/mdx": "^5.0.3",
    "@astrojs/netlify": "^7.0.6",
    "@astrojs/sitemap": "^3.7.2",
    "@iconify-json/logos": "^1.2.9",
    "@octokit/app": "^16.1.1",
    "@octokit/auth-app": "^8.1.1",
    "@octokit/rest": "^22.0.0",
    "@slack/web-api": "^7.15.0",
    "astro": "^6.1.4",
    "astro-icon": "^1.1.5",
    "dotenv": "^17.2.3",
    "remark-gfm": "^4.0.1",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.8",
    "@csstools/postcss-global-data": "^3.1.0",
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.59.1",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-astro": "^1.5.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "postcss-custom-media": "^11.0.6",
    "prettier": "^3.7.4",
    "prettier-plugin-astro": "^0.14.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.48.1"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "esbuild",
      "sharp"
    ]
  }
}
