    "astro": "^6.4.6",
    "sharp": "^0.35.1"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@csstools/postcss-global-data": "^4.0.0",
    "@eslint/js": "^10.0.1",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-astro": "^1.7.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "postcss-custom-media": "^12.0.1",
    "prettier": "^3.8.4",
    "prettier-plugin-astro": "^0.14.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0"
  }
