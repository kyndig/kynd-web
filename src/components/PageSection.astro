---
export type Props = {
  slug?: string;
  heading: string;
  subheading?: string;
  /** When true (default), the heading gets the green accent background. */
  accentHeading?: boolean;
};

const { slug, heading, subheading, accentHeading = true } = Astro.props;
---

<section id={slug}>
  <div class="heading-container">
    <h2 class:list={{ accent: accentHeading }}>{heading}</h2>
    {subheading && <div class="subheading">{subheading}</div>}
  </div>
  <slot />
</section>

<style>
  section {
    display: grid;
    gap: 2.5rem;

    @media (--md) {
      gap: 4rem;
    }
  }

  .heading-container {
    display: flex;
    flex-direction: column;
    align-items: start;
    column-gap: 2.5rem;
    row-gap: 1.5rem;

    @media (--md) {
      flex-direction: row;
      align-items: center;
    }
  }

  h2 {
    font-size: var(--fs-heading-m);
  }

  h2.accent {
    background-color: var(--color-accent);
    padding: 0.5rem;
  }

  .subheading {
    font-size: var(--fs-body-m);
    font-weight: 400;

    @media (--md) {
      max-width: 50%;
    }
  }
</style>
