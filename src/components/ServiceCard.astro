---
type Props = {
  title: string;
  description: string;
  outcome: string;
  variant?: 'default' | 'surface-low';
};

const { title, description, outcome, variant = 'default' } = Astro.props;
---

<article class:list={['service-card', variant]}>
  {
    Astro.slots.has('icon') && (
      <div class="service-icon">
        <slot name="icon" />
      </div>
    )
  }
  <h3>{title}</h3>
  <p>{description}</p>
  <p class="outcome"><strong>Typisk resultat:</strong> {outcome}</p>
</article>

<style>
  .service-card {
    border: 1px solid var(--color-border);
    background: var(--color-surface);
    padding: 1.5rem;
    display: grid;
    gap: 1rem;
  }

  .service-card.surface-low {
    background: var(--color-surface-low);
  }

  .service-icon {
    inline-size: 2rem;
    block-size: 2rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--color-primary);
    font-size: var(--fs-heading-s);
    font-weight: var(--font-weight-bold);
  }

  .service-card h3 {
    font-size: var(--fs-heading-xs);
    line-height: var(--line-height-m);
  }

  .service-card p {
    font-size: var(--fs-body-m);
  }

  .service-card .outcome {
    font-size: var(--fs-body-s);
  }
</style>
